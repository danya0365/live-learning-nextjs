# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Supabase Service Role Key (ใช้เฉพาะบน server-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Database URL for direct database access (ใช้สำหรับ migrations)
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Racing Game Station"

# Optional: Analytics (ถ้ามีการใช้งาน)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Optional: Storage Configuration
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# NEXT_PUBLIC_CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Optional: External APIs
# YOUTUBE_API_KEY=your-youtube-api-key

# Optional: Email Configuration
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=your-email-from-email
EMAIL_FROM_NAME=your-email-from-name


# ========================================
# Auth Configuration - Login Methods
# ========================================
# Email/Password login (default: enabled)
NEXT_PUBLIC_AUTH_EMAIL_ENABLED=true

# Allow new user registration (default: enabled)
NEXT_PUBLIC_AUTH_REGISTRATION_ENABLED=false

# Phone/OTP login (default: disabled)
NEXT_PUBLIC_AUTH_PHONE_ENABLED=false

# OAuth login (default: disabled)
NEXT_PUBLIC_AUTH_OAUTH_ENABLED=false

# Individual OAuth providers (only used if OAUTH_ENABLED=true)
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_FACEBOOK_ENABLED=false
NEXT_PUBLIC_AUTH_GITHUB_ENABLED=false
NEXT_PUBLIC_AUTH_LINE_ENABLED=false

# ========================================
# Auth Features
# ========================================
# Forgot password feature
NEXT_PUBLIC_AUTH_FORGOT_PASSWORD_ENABLED=true

# Email verification required
NEXT_PUBLIC_AUTH_EMAIL_VERIFICATION_ENABLED=true

# Remember me checkbox
NEXT_PUBLIC_AUTH_REMEMBER_ME_ENABLED=true

# ========================================
# LINE OA Chat Integration
# ========================================
# LINE Channel Access Token (from LINE Developers Console)
LINE_CHANNEL_ACCESS_TOKEN=
# LINE Channel Secret (from LINE Developers Console)
LINE_CHANNEL_SECRET=